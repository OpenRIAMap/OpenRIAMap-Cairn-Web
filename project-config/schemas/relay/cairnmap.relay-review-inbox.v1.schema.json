{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cairnmap.relay-review-inbox.v1.schema.json",
  "title": "CairnMap Relay Review Inbox Layout",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "inboxRoot", "summary", "packages"],
  "properties": {
    "schemaVersion": { "const": "cairnmap.relay-review-inbox.v1" },
    "generatedAt": { "type": "string" },
    "inboxRoot": { "type": "string" },
    "summary": { "type": "object", "additionalProperties": true },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["bucket", "packageId", "root", "statusPath", "status", "reports"],
        "properties": {
          "bucket": { "type": "string" },
          "packageId": { "type": "string" },
          "root": { "type": "string" },
          "statusPath": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] },
          "reports": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
