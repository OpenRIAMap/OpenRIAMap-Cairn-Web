{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cairnmap.local/schemas/relay/cairnmap.native-relay-pipeline-report.v1.schema.json",
  "title": "CairnMap Native Relay Local Pipeline Report v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "generatedAt",
    "projectId",
    "mode",
    "finalStatus",
    "inputs",
    "paths",
    "summary",
    "steps",
    "warnings",
    "errors"
  ],
  "properties": {
    "schemaVersion": { "const": "cairnmap.native-relay-pipeline-report.v1" },
    "generatedAt": { "type": "string" },
    "projectId": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["dry-run", "write"] },
    "finalStatus": { "enum": ["PASS", "FAIL"] },
    "inputs": { "type": "object", "additionalProperties": true },
    "paths": { "type": "object", "additionalProperties": { "type": "string" } },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["stepCount", "passedSteps", "failedSteps", "warningCount", "errorCount"],
      "properties": {
        "stepCount": { "type": "integer", "minimum": 0 },
        "passedSteps": { "type": "integer", "minimum": 0 },
        "failedSteps": { "type": "integer", "minimum": 0 },
        "warningCount": { "type": "integer", "minimum": 0 },
        "errorCount": { "type": "integer", "minimum": 0 }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "label", "script", "exitCode", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "script": { "type": "string", "minLength": 1 },
          "args": { "type": "array", "items": { "type": "string" } },
          "exitCode": { "type": "integer" },
          "status": { "enum": ["PASS", "FAIL"] },
          "stdoutTail": { "type": "array", "items": { "type": "string" } },
          "stderrTail": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
